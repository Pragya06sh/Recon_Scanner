# ─────────────────────────────────────────────────────
# ReconScanner — Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────────────

# Shodan API Key (free at https://account.shodan.io)
# Needed for --shodan flag
SHODAN_API_KEY=YOUR_SHODAN_API_KEY_HERE

# NVD API Key (free at https://nvd.nist.gov/developers/request-an-api-key)
# Optional — without it NVD is rate-limited to 5 req/30s (still works)
NVD_API_KEY=YOUR_NVD_API_KEY_HERE
